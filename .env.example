# =============================================================================
# LANDING — Environment Variables
# Copy to `.env` in this directory for local dev and server deploy.
# Nuxt reads this at build/dev; PM2 loads it at runtime (ecosystem.config.cjs).
# =============================================================================

# -----------------------------------------------------------------------------
# CORE / BUILD
# -----------------------------------------------------------------------------
NODE_ENV=development                     # development | production
LOCAL_LAYER=false                        # true = use local ../layout & ../api dirs instead of GitHub layers

# -----------------------------------------------------------------------------
# SITE
# -----------------------------------------------------------------------------
SITE_URL=https://example.com            # Canonical base URL (used by i18n and sitemap)
ACTIVE_VERSION=1                         # Active route version prefix (e.g. /v1/...)
VALID_DOMAIN=https://example.com        # Allowed domain for auth-check link validation
ENABLE_ANIMATIONS=true                   # Set to "false" to globally disable animations
HOSTNAME=example.com                     # Public hostname (exposed client-side)

# -----------------------------------------------------------------------------
# PAYLOAD CMS
# -----------------------------------------------------------------------------
PAYLOAD_BASE_URL=http://localhost:4050  # Payload CMS base URL (server + client SDK)

# -----------------------------------------------------------------------------
# SESSION (nuxt-auth-utils)
# -----------------------------------------------------------------------------
NUXT_SESSION_PASSWORD=                   # Min 32-char secret used to encrypt session cookies

# -----------------------------------------------------------------------------
# REDIS (Nitro cache storage)
# Redis driver defaults to localhost:6379. Override via env if using remote Redis.
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379       # Uncomment and set if using a remote Redis instance

# -----------------------------------------------------------------------------
# WHMCS / BILLING API
# -----------------------------------------------------------------------------
API_URL_WHMCS=https://whmcs.example.com/includes/api.php
API_IDENTIFIER=                          # WHMCS API identifier
API_SECRET=                              # WHMCS API secret
API_ACCESS=                              # WHMCS API access key
WHMCS_DB_URL=                            # Direct WHMCS database connection URL (e.g. mysql://user:pass@host/db)

# -----------------------------------------------------------------------------
# PRODUCT / GROUP IDs
# -----------------------------------------------------------------------------
GID=1                                    # Primary product group ID in WHMCS
RESELLER_GID=1                           # Reseller product group ID in WHMCS
UNAUTHORIZED_PIDS=                       # Comma-separated product IDs to block (e.g. 5,12,34)
HIDDEN_PID=                              # Comma-separated product IDs to hide from listing
HIDDEN_STATUS=                           # Comma-separated subscription statuses to hide (e.g. fraud,cancelled)
HIDDEN_DEP_ID=                           # Comma-separated department IDs to hide
TRIAL_PIDS=                              # Comma-separated trial product IDs
RESELLER_GROUPS=                         # Comma-separated reseller group IDs

# -----------------------------------------------------------------------------
# SUBSCRIPTION SORT ORDER
# Controls display order for subscription status groups (1 = first)
# -----------------------------------------------------------------------------
SUB_ACTIVE_ORDER=1
SUB_PENDING_ORDER=2
SUB_COMPLETED_ORDER=3
SUB_SUSPENDED_ORDER=4
SUB_TERMINATED_ORDER=5
SUB_CANCELLED_ORDER=6
SUB_FRAUD_ORDER=7

# -----------------------------------------------------------------------------
# PRODUCT HOST / STREAM CONFIG
# -----------------------------------------------------------------------------
PRODUCT_HOST_SSL=true                    # Whether the stream/product host uses SSL (true/false)
PRODUCT_HOST_PORT=8080                   # Port for the product/stream host
TRIAL_PORTAL_URL=                        # URL of the trial portal

# -----------------------------------------------------------------------------
# WHMCS CUSTOM FIELD NAMES
# Must match exact custom field names as configured in WHMCS
# -----------------------------------------------------------------------------
CF_USERNAME=Username
CF_PASSWORD=Password
CF_MAG_ADDRESS=MAG Address
CF_PARENTAL_CODE=Parental Code
CF_HOSTNAME=Hostname
CF_BOUQUET=Bouquet

# -----------------------------------------------------------------------------
# WHMCS CONFIG OPTION NAMES
# Must match exact configurable option names as set up in WHMCS
# -----------------------------------------------------------------------------
CO_EXTRA_CONNECTIONS=Extra Connections
CO_PROXY_PROTECTION=Proxy Protection

# -----------------------------------------------------------------------------
# RESELLER API
# -----------------------------------------------------------------------------
RESELLER_URL=                            # Reseller panel API base URL
RESELLER_API_KEY=                        # Reseller panel API key

# -----------------------------------------------------------------------------
# ROBOT / UPTIME MONITORING API
# -----------------------------------------------------------------------------
ROBOT_URL=                               # Uptime Robot / Robot API base URL
ROBOT_API_KEY=                           # Robot API key
ROBOT_MONITORS=                          # Comma-separated monitor IDs to display

# -----------------------------------------------------------------------------
# CHANNELS API
# -----------------------------------------------------------------------------
CHANNELS_API_URL=                        # API endpoint that returns channel list
CATEGORIES_API_URL=                      # API endpoint that returns channel categories

# -----------------------------------------------------------------------------
# PAYMENT GATEWAYS
# -----------------------------------------------------------------------------
# AstrumPay
ASTRUMPAY_URL=                           # AstrumPay payment gateway URL
ASTRUMPAY_KEY=                           # AstrumPay API key

# High-Risk / Mercuryo
HIGH_RISK_ADDRESS=                       # High-risk payment gateway address
HIGH_RISK_CALLBACK=                      # High-risk payment callback URL
ALLOW_MERCURYO=false                     # Allow Mercuryo crypto payments (true/false)

# Cryptomus (uses AstrumPay-style vars)
CRYPTO_ASTRUMPAY_URL=                    # Cryptomus payment URL
CRYPTO_ASTRUMPAY_KEY=                    # Cryptomus API key

# -----------------------------------------------------------------------------
# FRAUD DETECTION
# -----------------------------------------------------------------------------
CHECK_FRAUD=false                        # Enable IP-based fraud checking (true/false)
IP_API_KEY=                              # API key for IP geolocation service
VALID_COUNTRIES=                         # Allowed ISO country codes (e.g. US,GB,CA)

# -----------------------------------------------------------------------------
# AFFILIATES
# -----------------------------------------------------------------------------
AFF_MIN_WITHDRAWAL=10                    # Minimum withdrawal amount for affiliates
AFF_DEP_ID=                             # WHMCS department ID for affiliate requests
AFF_URLS=                               # Comma-separated affiliate tracking URLs

# -----------------------------------------------------------------------------
# SMTP — Primary
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDER_NAME=Support
SENDER_MAIL=support@example.com

# -----------------------------------------------------------------------------
# SMTP — Secondary / Failover
# -----------------------------------------------------------------------------
SMTP_HOST_SEC=
SMTP_PORT_SEC=587
SMTP_USER_SEC=
SMTP_PASS_SEC=

# -----------------------------------------------------------------------------
# ADMIN AUTH
# -----------------------------------------------------------------------------
AUTH_IDENTIFIER=                         # Admin panel identifier/username
AUTH_SECRET=                             # Admin panel secret/password
AUTH_NOTIFY_EMAIL=                       # Email address to notify on admin events

# -----------------------------------------------------------------------------
# TELEGRAM NOTIFICATIONS
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=                      # Telegram bot token (from @BotFather)
TELEGRAM_CHAT_ID=                        # Telegram chat/channel ID to send messages to

# -----------------------------------------------------------------------------
# SERVER MONITORING (client-side status display)
# -----------------------------------------------------------------------------
MONITORING=false                         # Enable monitoring widget (true/false)
MAIN_SERVER_NAME=                        # Display name for the main server
TV_SERVER_NAME=                          # Display name for the TV/live server
VOD_SERVER_NAME=                         # Display name for the VOD server

# -----------------------------------------------------------------------------
# SCRIPTS (not injected at runtime — only used by bun update:tmdb)
# -----------------------------------------------------------------------------
TMDB_API_KEY=                            # TMDB API bearer token (for update-tmdb-images.ts script)
